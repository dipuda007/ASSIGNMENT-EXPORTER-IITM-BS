{
  "manifest_version": 3,
  "name": "Assignment Copier",
  "version": "1.0.0",
  "description": "Capture & export your IITM SEEK assignment questions, options, code and tests as Markdown, JSON, image or PDF.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "sidePanel",
    "downloads",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://seek.study.iitm.ac.in/*",
    "https://backend.seek.study.iitm.ac.in/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Assignment Copier"
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://seek.study.iitm.ac.in/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://seek.study.iitm.ac.in/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
